# ==========================================
# Agent Configuration
# ==========================================
DEFAULT_PROVIDER="lmstudio"
DEFAULT_PROMPT="agent"
DEFAULT_MODEL="google/gemma-4-e4b"
TOOL_ITERATION_LIMIT=10

# ==========================================
# API Keys & Secrets
# ==========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=

# ==========================================
# Observability (Langfuse)
# ==========================================
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# ==========================================
# File Paths (optional overrides)
# ==========================================
PROMPTS_DIR="prompts"
CONFIG_DIR= "config"
DATA_DIR= "data"
